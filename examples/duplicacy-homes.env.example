# Example secrets file for remote backup mode.
# Place in /root/.secrets/duplicacy-<label>.env
#
# IMPORTANT:
#   - File must be owned by root:root
#   - File permissions must be 0600
#   - Only STORJ_S3_ID and STORJ_S3_SECRET keys are allowed
#
# To set correct permissions:
#   chown root:root /root/.secrets/duplicacy-homes.env
#   chmod 600 /root/.secrets/duplicacy-homes.env

STORJ_S3_ID=your-storj-s3-access-key-id-here
STORJ_S3_SECRET=your-storj-s3-secret-access-key-here
